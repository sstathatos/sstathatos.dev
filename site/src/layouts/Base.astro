---
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';
import '../styles/global.css';
import { person, skills } from '../data/cv';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// vertical side-strip content: every skill from the CV data, deduplicated;
// built as HTML so the trailing underscores keep the accent color
const stripWords = [...new Set(skills.flatMap((g) => g.items))];
const stripTrack =
  stripWords.map((w) => `${w.toUpperCase()}<span class="u">_</span>`).join('  //  ') + '  //  ';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = stored ?? preferred;
    </script>
  </head>
  <body>
    <div class="topbar">
      <div class="container topbar-inner">
        <span>WELCOME TO SSTATHATOS.DEV<span class="u">_</span></span>
        <a href={`mailto:${person.email}`}>{person.email.toUpperCase()}</a>
      </div>
    </div>

    <header class="container site-header">
      <a class="logo" href="/">sst<span class="u">_</span></a>
      <nav>
        <a href="#experience">Experience</a>
        <a href="#education">Education</a>
        <a href="#skills">Skills</a>
        <a href="#projects">Projects</a>
        <a href="#live">Live</a>
      </nav>
      <button id="theme-toggle" aria-label="Toggle dark mode" title="Toggle theme">&gt;/&lt;</button>
    </header>

    <aside class="side-strip" aria-hidden="true">
      <div class="strip-track">
        <span set:html={stripTrack} /><span set:html={stripTrack} />
      </div>
    </aside>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container site-footer">
        <p>
          <a href={`mailto:${person.email}`}>Email</a> ·
          <a href={person.github}>GitHub</a> ·
          <a href={person.linkedin}>LinkedIn</a>
        </p>
        <p class="colophon">
          Built with Astro, shipped by ArgoCD, running on k3s.
          <a href="https://github.com/sstathatos/sstathatos.dev">Source</a>
        </p>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>

<style>
  .u {
    color: var(--accent);
  }

  .topbar {
    border-bottom: 1px solid var(--line);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .topbar-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0 1rem;
    padding-top: 0.45rem;
    padding-bottom: 0.45rem;
  }

  .topbar a {
    text-decoration: none;
  }

  .site-header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem 2.5rem;
    padding-top: 1.4rem;
    padding-bottom: 1.4rem;
  }

  .logo {
    background: var(--chip-bg);
    color: var(--chip-text);
    font-weight: 700;
    font-size: 1.1rem;
    padding: 0.15rem 0.6rem;
    text-decoration: none;
    transform: rotate(-2deg);
    transition: transform 0.15s ease;
  }

  .logo:hover {
    color: var(--chip-text);
    transform: rotate(2deg) scale(1.06);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 2rem;
    flex: 1;
  }

  nav a {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
    text-decoration-thickness: 1px;
    transition: text-decoration-color 0.12s ease, color 0.12s ease;
  }

  nav a:hover {
    text-decoration-thickness: 3px;
    text-decoration-color: var(--accent);
  }

  @media (max-width: 40rem) {
    /* logo + toggle on the first row, nav on its own full-width row */
    nav {
      order: 3;
      flex-basis: 100%;
      gap: 0.5rem 1.1rem;
    }

    #theme-toggle {
      margin-left: auto;
    }

    nav a {
      font-size: 0.78rem;
      letter-spacing: 0.07em;
    }
  }

  #theme-toggle {
    background: none;
    color: var(--text);
    border: none;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
  }

  #theme-toggle:hover {
    color: var(--accent);
  }

  .side-strip {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: 2.6rem;
    background: var(--chip-bg);
    color: var(--accent);
    overflow: hidden;
    z-index: 10;
  }

  /* dark theme: match the name-label banner — beige with charcoal text
     (orange text on beige glares) */
  :global([data-theme='dark']) .side-strip {
    color: var(--chip-text);
  }

  /* underscores stay orange in both themes (set:html skips scoping) */
  .strip-track :global(.u) {
    color: var(--accent);
  }

  /* two identical spans scrolling upward = seamless vertical marquee */
  .strip-track {
    writing-mode: vertical-rl;
    display: flex;
    height: max-content;
    animation: strip-scroll 60s linear infinite;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: pre;
  }

  @keyframes strip-scroll {
    to {
      transform: translateY(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .strip-track {
      animation: none;
    }
  }

  @media (max-width: 60rem) {
    .side-strip {
      display: none;
    }
  }

  footer {
    border-top: 1px solid var(--line);
  }

  .site-footer {
    padding-top: 2rem;
    padding-bottom: 3rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    display: grid;
    gap: 0.4rem;
  }

  .colophon {
    font-size: 0.75rem;
  }
</style>
