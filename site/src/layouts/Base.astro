---
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';
import '../styles/global.css';
import { person } from '../data/cv';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.dataset.theme = stored ?? preferred;
    </script>
  </head>
  <body>
    <div class="topbar">
      <div class="container topbar-inner">
        <span>WELCOME TO SSTATHATOS.DEV<span class="u">_</span></span>
        <a href={`mailto:${person.email}`}>{person.email.toUpperCase()}</a>
      </div>
    </div>

    <header class="container site-header">
      <a class="logo" href="/">s7s<span class="u">_</span></a>
      <nav>
        <a href="#experience">Experience</a>
        <a href="#education">Education</a>
        <a href="#skills">Skills</a>
        <a href="#projects">Projects</a>
      </nav>
      <button id="theme-toggle" aria-label="Toggle dark mode" title="Toggle theme">&gt;/&lt;</button>
    </header>

    <aside class="side-strip" aria-hidden="true">
      DevOps Engineering | Kubernetes | GitOps | Terraform | CI/CD<span class="u">_</span>
    </aside>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container site-footer">
        <p>
          <a href={`mailto:${person.email}`}>Email</a> ·
          <a href={person.github}>GitHub</a> ·
          <a href={person.linkedin}>LinkedIn</a>
        </p>
        <p class="colophon">
          Built with Astro, shipped by ArgoCD, running on k3s.
          <a href="https://github.com/sstathatos/sstathatos.dev">Source</a>
        </p>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>

<style>
  .u {
    color: var(--accent);
  }

  .topbar {
    border-bottom: 1px solid var(--line);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
  }

  .topbar-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.45rem;
    padding-bottom: 0.45rem;
  }

  .topbar a {
    text-decoration: none;
  }

  .site-header {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding-top: 1.4rem;
    padding-bottom: 1.4rem;
  }

  .logo {
    background: var(--chip-bg);
    color: var(--chip-text);
    font-weight: 700;
    font-size: 1.1rem;
    padding: 0.15rem 0.6rem;
    text-decoration: none;
  }

  .logo:hover {
    color: var(--chip-text);
  }

  nav {
    display: flex;
    gap: 2rem;
    flex: 1;
  }

  nav a {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  #theme-toggle {
    background: none;
    color: var(--text);
    border: none;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
  }

  #theme-toggle:hover {
    color: var(--accent);
  }

  .side-strip {
    position: fixed;
    top: 0;
    right: 0;
    height: 100vh;
    width: 2.6rem;
    background: var(--chip-bg);
    color: var(--accent);
    writing-mode: vertical-rl;
    display: flex;
    align-items: center;
    padding: 1.5rem 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    z-index: 10;
  }

  @media (max-width: 60rem) {
    .side-strip {
      display: none;
    }
  }

  footer {
    border-top: 1px solid var(--line);
  }

  .site-footer {
    padding-top: 2rem;
    padding-bottom: 3rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    display: grid;
    gap: 0.4rem;
  }

  .colophon {
    font-size: 0.75rem;
  }
</style>
