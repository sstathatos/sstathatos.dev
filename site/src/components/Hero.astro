---
import { person } from '../data/cv';
---

<div class="hero">
  <div class="ghost" aria-hidden="true">DEVOPS</div>

  <div class="intro">
    <span class="label">Stefanos Stathatos · DevOps Engineer</span>
    <h1>
      Automate<span class="u">_</span><br />
      Deploy<span class="u">_</span><br />
      Observe<span class="u cursor">_</span>
    </h1>
  </div>

  <div class="aside">
    <p class="summary">{person.summary}</p>
    <div class="actions">
      <a class="btn primary" href={person.cvFile} download>Download CV</a>
      <a class="btn" href={`mailto:${person.email}`}>Email</a>
      <a class="btn" href={person.github}>GitHub</a>
      <a class="btn" href={person.linkedin}>LinkedIn</a>
    </div>
  </div>

</div>

<style>
  .u {
    color: var(--accent);
  }

  /* terminal cursor blink on the final underscore */
  .cursor {
    animation: blink 1.1s steps(1) infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cursor {
      animation: none;
    }
  }

  .hero {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: 2rem 3rem;
    padding: 4.5rem 0 4rem;
    overflow: hidden;
    /* subtle plotter-paper dot grid behind the hero */
    background-image: radial-gradient(var(--ghost) 1.5px, transparent 1.5px);
    background-size: 26px 26px;
  }

  .ghost {
    position: absolute;
    top: 0.5rem;
    left: -0.5rem;
    font-size: clamp(6rem, 22vw, 16rem);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 2px var(--ghost);
    letter-spacing: -0.02em;
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  .intro {
    position: relative;
  }

  h1 {
    margin-top: 1.2rem;
    font-size: clamp(2.4rem, 7vw, 4.6rem);
    color: var(--accent);
    letter-spacing: -0.01em;
  }

  .aside {
    position: relative;
    align-self: end;
    display: grid;
    gap: 1.6rem;
  }

  .summary {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  @media (max-width: 60rem) {
    .hero {
      grid-template-columns: 1fr;
    }
  }
</style>
